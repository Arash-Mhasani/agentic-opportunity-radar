# ── Models (the swappable half of Agent = Model + Harness) ────────────────────
ANTHROPIC_API_KEY=            # required for live runs; leave blank to run offline
RADAR_OFFLINE=0              # set 1 to force the deterministic offline responder

# Optional: heterogeneous judge for the Elo tournament (reduces self-eval bias)
GEMINI_API_KEY=
RADAR_MODEL_JUDGE=gemini-2.5-pro

# Optional overrides (defaults are the correct current model IDs)
# RADAR_MODEL_BUSINESS=claude-opus-4-8
# RADAR_MODEL_CURATION=claude-sonnet-4-6
# RADAR_MODEL_SOURCE=claude-sonnet-4-6
# RADAR_MODEL_CHEAP=claude-haiku-4-5

# ── Denial-of-Wallet budget (per cycle) ───────────────────────────────────────
RADAR_MAX_MODEL_CALLS=200
RADAR_MAX_TOOL_ITERS=6
RADAR_MAX_USD=15

# ── Deterministic guardrails ──────────────────────────────────────────────────
RADAR_MIN_RESEARCH_SIGNALS=100

# ── Notion (CONSUMED via official MCP — reads your workspace, writes your report) ─
# Use an internal integration token (ntn_...). Read-only token for reads; a
# write-scoped token only if you want the HITL-gated report write.
NOTION_TOKEN=
NOTION_READ_ONLY=1                 # 1 = block all writes; 0 = allow writes (still HITL-gated)
RADAR_REQUIRE_WRITE_CONFIRMATION=1 # Human-In-The-Loop gate before any Notion write
NOTION_PARENT_PAGE_ID=             # page/data-source id to write the daily report under

# ── YouTube (CONSUMED via yt-mcp — reads YOUR OWN playlist + transcripts) ─────
YOUTUBE_API_KEY=
YOUTUBE_PLAYLIST_ID=               # your curated playlist id to pull video signals from
# For private lists (getMyPlaylists), also set OAuth:
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=

# ── GitHub (CONSUMED via official GitHub MCP, read-only) ──────────────────────
GITHUB_TOKEN=

# ── Storage ───────────────────────────────────────────────────────────────────
# RADAR_DB_PATH=./agentic_radar/memory/dynamic_memory.db
# RADAR_BUS_DIR=./agentic_radar/message_bus
